# OpenClaw Fly.io Dockerfile with auto-config for DashScope
FROM ghcr.io/openclaw/openclaw:latest

# Create entrypoint script that initializes config on first boot
RUN printf '#!/bin/sh\n\
set -e\n\
\n\
# Initialize config on first run\n\
if [ ! -f /data/openclaw.json ]; then\n\
  echo "Creating initial OpenClaw config..."\n\
  mkdir -p /data\n\
  cat > /data/openclaw.json << EOF\n\
{\n\
  "agent": {\n\
    "model": "openai/glm-5",\n\
    "thinking": "medium"\n\
  },\n\
  "agents": {\n\
    "defaults": {\n\
      "model": "openai/qwen3.5-plus",\n\
      "thinking": "medium"\n\
    }\n\
  }\n\
}\n\
EOF\n\
  echo "Config created at /data/openclaw.json"\n\
fi\n\
\n\
# Start gateway with allow-unconfigured for safety\n\
exec /usr/local/bin/openclaw gateway --bind 0.0.0.0 --port 3000 --allow-unconfigured\n' > /entrypoint.sh && chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
